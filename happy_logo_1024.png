
<div style="display:flex;flex-direction:column;align-items:center;gap:16px;padding:40px 0;">
  <canvas id="logo1024" width="512" height="512" style="border-radius:120px;width:300px;height:300px;"></canvas>
  <button onclick="downloadLogo()" style="background:#1C3D2B;color:#F5F0E8;border:none;padding:12px 28px;font-size:13px;font-weight:500;border-radius:100px;cursor:pointer;letter-spacing:0.06em;">Download PNG</button>
</div>

<script>
const canvas = document.getElementById('logo1024');
const ctx = canvas.getContext('2d');
const s = 512;

ctx.fillStyle = '#1C3D2B';
ctx.fillRect(0, 0, s, s);

ctx.font = 'italic 360px Georgia, serif';
ctx.fillStyle = '#F5F0E8';
ctx.textBaseline = 'middle';
ctx.textAlign = 'center';
ctx.fillText('h', s/2, s/2 + 20);

function downloadLogo() {
  const link = document.createElement('a');
  link.download = 'happy-golf-icon.png';
  link.href = canvas.toDataURL('image/png');
  link.click();
}
</script>
